#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROTO_DIR="$ROOT_DIR/protobuf"
GO_OUT_DIR="$ROOT_DIR/server/protomsg"
GO_IMPORT_PATH="github.com/ppgram/server/protomsg"

if ! command -v protoc >/dev/null 2>&1; then
  echo "error: protoc is not installed or not in PATH" >&2
  exit 1
fi

if ! command -v protoc-gen-go >/dev/null 2>&1; then
  echo "error: protoc-gen-go is not installed or not in PATH" >&2
  echo "install with: go install google.golang.org/protobuf/cmd/protoc-gen-go@latest" >&2
  exit 1
fi

if [ ! -d "$PROTO_DIR" ]; then
  echo "error: protobuf directory not found at $PROTO_DIR" >&2
  exit 1
fi

mapfile -t PROTO_FILES < <(find "$PROTO_DIR" -maxdepth 1 -type f -name '*.proto' | sort)

if [ "${#PROTO_FILES[@]}" -eq 0 ]; then
  echo "no .proto files found under $PROTO_DIR"
  exit 0
fi

rm -rf "$GO_OUT_DIR"
mkdir -p "$GO_OUT_DIR"

GO_MAP_OPTS=()
for file in "${PROTO_FILES[@]}"; do
  rel="${file#$PROTO_DIR/}"
  GO_MAP_OPTS+=(--go_opt="M${rel}=${GO_IMPORT_PATH}")
done

protoc \
  -I "$PROTO_DIR" \
  --go_out="$GO_OUT_DIR" \
  --go_opt=paths=source_relative \
  "${GO_MAP_OPTS[@]}" \
  "${PROTO_FILES[@]}"

mapfile -t GO_FILES < <(find "$GO_OUT_DIR" -type f -name '*.pb.go' | sort)
for file in "${GO_FILES[@]}"; do
  base="$(basename "$file")"
  target="$GO_OUT_DIR/$base"
  if [ "$file" = "$target" ]; then
    continue
  fi
  if [ -e "$target" ]; then
    echo "error: Go filename collision while flattening: $base" >&2
    exit 1
  fi
  mv "$file" "$target"
done
find "$GO_OUT_DIR" -type d -empty -delete

echo "generated Go files in: $GO_OUT_DIR"
