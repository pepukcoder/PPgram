#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
SECRETS_DIR="$ROOT_DIR/secrets"
CERTS_DIR="$ROOT_DIR/certs"
KEY_FILE="${1:-$SECRETS_DIR/server.key.pem}"
CERT_FILE="${2:-$CERTS_DIR/server.cert.pem}"
DAYS="${DAYS:-365}"
COMMON_NAME="${COMMON_NAME:-localhost}"

mkdir -p "$(dirname "$KEY_FILE")" "$(dirname "$CERT_FILE")"
umask 077

openssl req \
	-x509 \
	-nodes \
	-newkey rsa:2048 \
	-sha256 \
	-days "$DAYS" \
	-subj "/CN=$COMMON_NAME" \
	-addext "subjectAltName=DNS:localhost,IP:127.0.0.1,IP:::1" \
	-addext "keyUsage=critical,digitalSignature,keyEncipherment" \
	-addext "extendedKeyUsage=serverAuth" \
	-keyout "$KEY_FILE" \
	-out "$CERT_FILE"

chmod 600 "$KEY_FILE"
chmod 644 "$CERT_FILE"

printf 'generated key:  %s\n' "$KEY_FILE"
printf 'generated cert: %s\n' "$CERT_FILE"
